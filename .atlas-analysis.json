  "keyFeatures": [
    "AI-powered OCR extraction from 30+ document types including Aadhaar, PAN, GST, invoices, and property documents",
    "Flow-based document verification with callback support for async processing",
    "Cross-document field validation to detect inconsistencies across uploaded documents",
    "Batch document processing for high-volume use cases",
    "Fuzzy address matching with similarity scores for KYC address verification",
    "Chat-based onboarding flow for customer-facing document collection",
    "Sandbox environment for integration testing without production data",
    "JWT-based authentication with token refresh support"
  ],
